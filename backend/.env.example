PORT=8080
NODE_ENV=development

# Copy this file to backend/.env and fill in real values locally.
MONGODB_URI=MongoDB_url
MONGODB_FORCE_IPV4=false
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

JWT_SECRET=replace_with_a_64_byte_random_hex_string
JWT_EXPIRES_IN=7d
ANTHROPIC_API_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@scoreflow.ai

N8N_SUBMISSION_WEBHOOK=http://localhost:5678/webhook/submission-received
N8N_SCORE_RELEASE_WEBHOOK=http://localhost:5678/webhook/score-released

CLIENT_URL=http://localhost:5173
